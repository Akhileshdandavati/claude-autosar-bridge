<?xml version='1.0' encoding='UTF-8'?>
<AUTOSAR xmlns="http://autosar.org/schema/r4.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://autosar.org/schema/r4.0 AUTOSAR_00051.xsd">
  <AR-PACKAGES>
    <AR-PACKAGE>
      <SHORT-NAME>Components</SHORT-NAME>
      <ELEMENTS>
        <APPLICATION-SW-COMPONENT-TYPE>
          <SHORT-NAME>BrakeActuator</SHORT-NAME>
          <PORTS>
            <P-PORT-PROTOTYPE>
              <SHORT-NAME>BrakeCommandPort</SHORT-NAME>
              <PROVIDED-INTERFACE-TREF DEST="SENDER-RECEIVER-INTERFACE">/Interfaces/BrakeCommandInterface</PROVIDED-INTERFACE-TREF>
            </P-PORT-PROTOTYPE>
          </PORTS>
          <INTERNAL-BEHAVIORS>
            <SWC-INTERNAL-BEHAVIOR>
              <SHORT-NAME>BrakeActuator_IB</SHORT-NAME>
              <EVENTS>
                <TIMING-EVENT>
                  <SHORT-NAME>TE_Run5ms</SHORT-NAME>
                  <START-ON-EVENT-REF DEST="RUNNABLE-ENTITY">/Components/BrakeActuator/BrakeActuator_IB/Run5ms</START-ON-EVENT-REF>
                  <PERIOD>0.005</PERIOD>
                </TIMING-EVENT>
                <INIT-EVENT>
                  <SHORT-NAME>IE_InitBrakeActuator</SHORT-NAME>
                  <START-ON-EVENT-REF DEST="RUNNABLE-ENTITY">/Components/BrakeActuator/BrakeActuator_IB/InitBrakeActuator</START-ON-EVENT-REF>
                </INIT-EVENT>
              </EVENTS>
              <RUNNABLES>
                <RUNNABLE-ENTITY>
                  <SHORT-NAME>Run5ms</SHORT-NAME>
                  <DATA-WRITE-ACCESSS>
                    <VARIABLE-ACCESS>
                      <SHORT-NAME>VA_Run5ms_BrakeCommandPort</SHORT-NAME>
                      <ACCESSED-VARIABLE>
                        <AUTOSAR-VARIABLE-IREF>
                          <PORT-PROTOTYPE-REF DEST="P-PORT-PROTOTYPE">/Components/BrakeActuator/BrakeCommandPort</PORT-PROTOTYPE-REF>
                          <TARGET-DATA-PROTOTYPE-REF DEST="VARIABLE-DATA-PROTOTYPE">/Interfaces/BrakeCommandInterface/BrakeTorque</TARGET-DATA-PROTOTYPE-REF>
                        </AUTOSAR-VARIABLE-IREF>
                      </ACCESSED-VARIABLE>
                    </VARIABLE-ACCESS>
                  </DATA-WRITE-ACCESSS>
                </RUNNABLE-ENTITY>
                <RUNNABLE-ENTITY>
                  <SHORT-NAME>InitBrakeActuator</SHORT-NAME>
                </RUNNABLE-ENTITY>
              </RUNNABLES>
            </SWC-INTERNAL-BEHAVIOR>
          </INTERNAL-BEHAVIORS>
        </APPLICATION-SW-COMPONENT-TYPE>
      </ELEMENTS>
    </AR-PACKAGE>
  </AR-PACKAGES>
</AUTOSAR>
